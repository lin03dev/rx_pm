# Copy to passwords.env and adjust if needed.
# passwords.env is gitignored.

LMS_CONNECTION_STRING=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
AG_CONNECTION_STRING=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
TELIOS_CONNECTION_STRING=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Optional local development overrides
AG_DEV_HOST=localhost
AG_DEV_PORT=5432
AG_DEV_DATABASE=AG_Dev
AG_DEV_USER=postgres
AG_DEV_PASSWORD=postgres

LMS_DEV_HOST=localhost
LMS_DEV_PORT=5432
LMS_DEV_DATABASE=LMS_Survey_Dev
LMS_DEV_USER=postgres
LMS_DEV_PASSWORD=postgres

TELIOS_DEV_HOST=localhost
TELIOS_DEV_PORT=5432
TELIOS_DEV_DATABASE=Telios_Dev
TELIOS_DEV_USER=postgres
TELIOS_DEV_PASSWORD=postgres
